# Telegram bot token from @BotFather
BOT_TOKEN=

# Concurrency for fast HTTP fetches
MAX_CONCURRENCY=50

# Parallel Chrome pages for browser fallback (used on 403/429/auth)
BROWSER_CONCURRENCY=5

# Per-URL HTTP fetch timeout (ms)
NAV_TIMEOUT_MS=15000

# Only download first N bytes of each URL
FETCH_BYTE_LIMIT=98304

# Retries on transient errors (429/5xx/network)
RETRIES_ON_ERROR=2


# Inline message threshold — if valid OR invalid count <= this, send inline;
# otherwise upload as .txt file.
INLINE_LIMIT=50

# Telegram message edit throttle for live progress (ms)
PROGRESS_EDIT_INTERVAL_MS=2000

# Comma-separated Telegram user IDs that may use the bot. Empty = public.
ALLOWED_USER_IDS=

# Hard cap on links per single job
MAX_LINKS_PER_JOB=20000

# HTTP statuses that trigger browser fallback (real Chrome with cookies)
BROWSER_FALLBACK_HTTP_STATUSES=401,403,429

# Persistent Chrome profile (for fallback — login with `npm run login`)
CHROME_PROFILE_DIR=/root/tg-checker-chrome-profile
CHROME_CHANNEL=chrome
HEADFUL=false

# Optional extra markers (comma-separated, lowercase)
INVALID_TEXT_PATTERNS=
VALID_TEXT_PATTERNS=
