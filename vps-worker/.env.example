# ===== Supabase =====
SUPABASE_URL=https://eygkdpfjrjwwbiackfpr.supabase.co
# Service role key (admin) — Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===== Chrome profile (cookies source) =====
# Persistent profile directory. Once you login here via `node login.js`,
# the Google cookies are reused by every fast-fetch request — no tabs needed.
CHROME_PROFILE_DIR=/root/chrome-profile

# Use real Google Chrome for best Google-login compatibility.
# Install google-chrome-stable on VPS, then keep this as chrome.
CHROME_CHANNEL=chrome
# Optional override if Chrome is in a custom path.
CHROME_EXECUTABLE_PATH=

# Set to "true" to open the browser window when running `node login.js`
# via noVNC. The worker itself always runs headless.
HEADFUL=false

# ===== Worker tuning =====
# Max parallel workers per job. Fast-fetch mode is network-bound (low CPU/RAM),
# so on an 8GB VPS 25 is a safe sweet spot (~150–200 MB worker RAM total +
# Chrome ~400 MB idle). Bump to 30 if your network handles it; drop to 15 if
# you start seeing 429s from Google.
MAX_CONCURRENCY=25
# How often to poll for new jobs (ms).
POLL_INTERVAL_MS=5000
# Per-URL HTTP fetch timeout (ms).
NAV_TIMEOUT_MS=15000
# How many extra retries on transient errors (429/5xx/timeout only).
RETRIES_ON_ERROR=2
# Delay between consecutive jobs in the SAME worker (ms). 0 = no throttle.
DELAY_BETWEEN_JOBS_MS=50
# Cap response body bytes (sent as Range header). 96 KB is plenty for the
# Google text markers and cuts bandwidth/parse time dramatically.
FETCH_BYTE_LIMIT=98304

# ===== Validity detection (optional extras) =====
# Comma-separated case-insensitive markers. The built-in extension markers
# ("already been used", "new activation link") are ALWAYS active — these are
# additional patterns you can add.
INVALID_TEXT_PATTERNS=
# Optional positive markers. Leave empty to mark anything without an invalid
# marker as VALID (matches extension behaviour).
VALID_TEXT_PATTERNS=
