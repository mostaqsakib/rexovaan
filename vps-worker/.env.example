# ===== Supabase =====
SUPABASE_URL=https://eygkdpfjrjwwbiackfpr.supabase.co
# Service role key (admin) — get from Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===== Chrome profile =====
# Persistent profile directory. Once you login here it stays logged in forever.
CHROME_PROFILE_DIR=/root/chrome-profile

# Set to "true" to see the browser window (use with noVNC). false = headless.
HEADFUL=false

# ===== Worker tuning =====
# Concurrency limit cap (per-job concurrency is also stored in DB)
MAX_CONCURRENCY=10
# How often to poll for new jobs (ms)
POLL_INTERVAL_MS=5000
# Per-URL navigation timeout (ms)
NAV_TIMEOUT_MS=30000

# ===== Validity detection =====
# Page text (case-insensitive, comma-separated) that means the link is INVALID
INVALID_TEXT_PATTERNS=already been redeemed,already redeemed,no longer available,offer has expired,not eligible,invalid code,cannot be used,is not valid,already claimed,sign in to continue
# Page text that means the link is VALID (subscription page loaded properly)
VALID_TEXT_PATTERNS=subscribe,continue,confirm subscription,start your,activate
